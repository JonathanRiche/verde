#include <metal_stdlib>
using namespace metal;

struct FSInput {
    float4 position [[position]];
    float2 uv;
    float4 color;
    float2 pixel_pos;
    float2 sdf_min;
    float2 sdf_size;
    float2 sdf_radius_border;
    float4 sdf_border;
};

fragment float4 palette_image_fragment(
    FSInput input [[stage_in]],
    texture2d<float> image_texture [[texture(0)]],
    sampler image_sampler [[sampler(0)]]
) {
    return image_texture.sample(image_sampler, input.uv) * input.color;
}
